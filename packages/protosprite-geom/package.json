{
  "name": "protosprite-geom",
  "type": "module",
  "version": "0.2.2",
  "description": "Polygon geometry tracing and encoding for protosprite",
  "main": "dist/core.js",
  "types": "dist/src/core/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/core.js",
      "types": "./dist/src/core/index.d.ts"
    },
    "./trace": {
      "default": "./dist/trace.js",
      "types": "./dist/src/trace/index.d.ts"
    }
  },
  "sideEffects": false,
  "keywords": [
    "protobuf",
    "sprites",
    "geometry",
    "polygon"
  ],
  "author": "Robert Brownstein",
  "license": "MIT",
  "scripts": {
    "build:clean": "rm -rf ./proto_dist ./dist",
    "build:buf": "buf generate",
    "build:rollup": "rollup -c",
    "build": "npm run build:clean && npm run build:buf && npm run build:rollup",
    "prepublish": "npm run build"
  },
  "directories": {
    "src": "src",
    "dist": "dist",
    "proto_dist": "proto_dist"
  },
  "files": [
    "src",
    "dist",
    "proto_dist"
  ],
  "dependencies": {
    "@bufbuild/buf": "^1.56.0",
    "@bufbuild/protobuf": "^2.7.0",
    "@bufbuild/protoc-gen-es": "^2.7.0",
    "jimp": "^1.6.0",
    "marchingsquares": "^1.3.3",
    "poly-decomp": "^0.3.0",
    "protosprite-core": "^0.2.2",
    "simplify-js": "^1.2.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.4",
    "rollup": "^4.48.1"
  },
  "gitHead": "842676edbb77aff985b2d3acd67324be4cecd753"
}
